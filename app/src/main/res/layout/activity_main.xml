<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#EAF2FF"
    android:textSize="18sp"
    android:elevation="4dp"
    android:gravity="center_horizontal"
    android:paddingTop="48dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Título -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌦 Weather Now"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#1F2A44"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Consulte o clima da sua cidade"
            android:textSize="16sp"
            android:textColor="#555555"
            android:layout_marginBottom="20dp"/>

        <!-- Campo -->
        <EditText
            android:id="@+id/inputCidade"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Digite a cidade"
            android:background="@android:drawable/editbox_background"
            android:padding="12dp" />

        <!-- Botão -->
        <Button
            android:id="@+id/botaoBuscar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Consultar clima"
            android:layout_marginTop="16dp"
            android:backgroundTint="#4A6CF7"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <!-- Card do resultado -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="24dp"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Resultado"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/textoResultado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Digite uma cidade para consultar"
                android:textSize="16sp"
                android:lineSpacingExtra="4dp"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>